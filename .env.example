# GeekAI 中转（OpenAI 兼容）
GEEKAI_API_KEY=your-geekai-key
GEEKAI_BASE_URL=https://geekai.co/api/v1
DEFAULT_MODEL=gpt-5-mini

# 本地 PostgreSQL（docker compose up postgres）
DATABASE_URL=postgresql://llmops:llmops@localhost:5432/llmops

# App
APP_ENV=development
LOG_LEVEL=INFO
ALLOW_ONLINE_API=false
FAISS_INDEX_PATH=./data/faiss_index
# mock = 本地伪向量，不调用云端，可联调入库/RAG；openai = 走 GeekAI
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=
EMBEDDING_DIM=1536
EMBEDDING_DEVICE=cuda

# Mock RAG：固定输入返回固定检索片段，便于不调用云端 API 联调
MOCK_RAG_ENABLED=true
MOCK_RAG_QUERY=年假几天？
MOCK_RAG_SOURCE=mock-hr
MOCK_RAG_CONTEXT=公司年假是15天。
