# GeekAI 中转（OpenAI 兼容）—— 对话 LLM 走 API
GEEKAI_API_KEY=your-geekai-key
GEEKAI_BASE_URL=https://geekai.co/api/v1
DEFAULT_MODEL=deepseek-v4-flash

# 本地 PostgreSQL（docker compose up postgres）
DATABASE_URL=postgresql://llmops:llmops@localhost:5432/llmops

# App
APP_ENV=development
LOG_LEVEL=INFO
ALLOW_ONLINE_API=true
FAISS_INDEX_PATH=./data/faiss_index

# --- Embedding 配置 ------------------------------------------------
# 来源：mock（联调）| openai（云端/Xinference OpenAI 兼容）| local（HuggingFace/TEI）
EMBEDDING_PROVIDER=mock

# mock 联调（不调用 embedding API）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=
EMBEDDING_DIM=1536
EMBEDDING_DEVICE=cuda

# local 模式（Win PC HuggingFace / TEI / Xinference embedding）
# EMBEDDING_PROVIDER=local
# EMBEDDING_BACKEND=tei
# EMBEDDING_MODEL=bge-base-zh-v1.5-<uid>
# EMBEDDING_DIM=768
# EMBEDDING_DEVICE=cuda
# EMBEDDING_API_BASE=http://127.0.0.1:9997/v1
# EMBEDDING_API_KEY=xinference

# local 模式（进程内 HuggingFace，需本机装 torch）
# EMBEDDING_PROVIDER=local
# EMBEDDING_BACKEND=huggingface
# EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
# EMBEDDING_DIM=768
# EMBEDDING_DEVICE=cuda

# openai 模式（走 GeekAI 或 Xinference OpenAI 兼容 embedding）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=bge-base-zh-v1.5-<uid>
# EMBEDDING_DIM=768

# Mock RAG：固定输入返回固定检索片段，便于不调用云端 API 联调
MOCK_RAG_ENABLED=true
MOCK_RAG_QUERY=年假几天？
MOCK_RAG_SOURCE=mock-hr
MOCK_RAG_CONTEXT=公司年假是15天。
MOCK_CHAT_ENABLED=true
MOCK_CHAT_REPLY=根据 mock 知识库，公司年假是15天。

# --- 本地 Xinference（docker compose up xinference -d）---
# 启动后打开 http://127.0.0.1:9997 Launch 模型，把 Running Models 里的 uid 填到上方
# Chat 仍走 GeekAI 时，只改 embedding 相关即可
# GEEKAI_BASE_URL=http://127.0.0.1:9997/v1
# GEEKAI_API_KEY=xinference
# DEFAULT_MODEL=qwen2.5-instruct-<uid>
# ALLOW_ONLINE_API=true
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=bge-base-zh-v1.5-<uid>
# EMBEDDING_DIM=768
# MOCK_RAG_ENABLED=false
# MOCK_CHAT_ENABLED=false

# --- 本地 Ollama ---
# GEEKAI_BASE_URL=http://localhost:11434/v1
# GEEKAI_API_KEY=ollama
# DEFAULT_MODEL=qwen2.5:7b
# ALLOW_ONLINE_API=true
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768
# MOCK_RAG_ENABLED=false
# MOCK_CHAT_ENABLED=false
