# GeekAI 中转（OpenAI 兼容）—— 对话 LLM 走 API
GEEKAI_API_KEY=your-geekai-key
GEEKAI_BASE_URL=https://geekai.co/api/v1
DEFAULT_MODEL=gpt-5-mini

# 本地 PostgreSQL（docker compose up postgres）
DATABASE_URL=postgresql://llmops:llmops@localhost:5432/llmops

# App
APP_ENV=development
LOG_LEVEL=INFO
ALLOW_ONLINE_API=true
FAISS_INDEX_PATH=./data/faiss_index

# --- Embedding 配置 ------------------------------------------------
# 来源：mock（联调）| openai（云端）| local（HuggingFace 本地/远程）
EMBEDDING_PROVIDER=mock

# mock 联调（不调用 embedding API）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=
EMBEDDING_DIM=1536
EMBEDDING_DEVICE=cuda

# local 模式（Win PC HuggingFace / TEI，晚上部署后启用）
# EMBEDDING_PROVIDER=local
# EMBEDDING_BACKEND=tei
# EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
# EMBEDDING_DIM=768
# EMBEDDING_DEVICE=cuda
# EMBEDDING_API_BASE=http://192.168.x.x:8080/v1
# EMBEDDING_API_KEY=

# openai 模式（走 GeekAI embedding）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# Mock RAG：固定输入返回固定检索片段，便于不调用云端 API 联调
MOCK_RAG_ENABLED=true
MOCK_RAG_QUERY=年假几天？
MOCK_RAG_SOURCE=mock-hr
MOCK_RAG_CONTEXT=公司年假是15天。
MOCK_CHAT_ENABLED=true
MOCK_CHAT_REPLY=根据 mock 知识库，公司年假是15天。
